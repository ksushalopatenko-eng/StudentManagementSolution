@page
@model StudentManagementWeb.Pages.Courses.DeleteModel

<h1>Delete course</h1>

@if (Model.Course is null)
{
    <p>Course not found.</p>
}
else
{
    <p>Are you sure you want to delete this course?</p>
    <ul>
        <li><strong>Id:</strong> @Model.Course.Id</li>
        <li><strong>Title:</strong> @Model.Course.Title</li>
    </ul>

    <form method="post">
        <input type="hidden" asp-for="Id" />
        <button class="btn btn-danger" type="submit">Delete</button>
        <a class="btn btn-secondary" href="/Courses">Cancel</a>
    </form>
}