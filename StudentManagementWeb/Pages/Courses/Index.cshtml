@page
@model StudentManagementWeb.Pages.Courses.IndexModel

<h1>Courses</h1>

<p>
    <a class="btn btn-primary" href="/Courses/Create">Add course</a>
</p>

<form method="get" class="mb-3 d-flex gap-2">
    <input class="form-control"
           type="text"
           name="Search"
           value="@Model.Search"
           placeholder="Search by title..." />

    <button class="btn btn-primary" type="submit">Search</button>
    <a class="btn btn-secondary" href="/Courses">Clear</a>
</form>

@if (Model.HasSearch)
{
    <h2>Search results</h2>

    @if (!Model.HasResults)
    {
        <div class="alert alert-warning">
            No courses found for "@Model.Search".
        </div>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Title</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model.SearchResults)
            {
                <tr class="table-warning">
                    <td>@c.Id</td>
                    <td><strong>@c.Title</strong></td>
                    <td style="display:flex; gap:8px;">
                        <a class="btn btn-sm btn-secondary" href="/Courses/Edit?id=@c.Id">Edit</a>

                        <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id">
                            <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                        </form>

                        <a class="btn btn-sm btn-outline-primary"
                           href="/Enrollments/CourseStudents?courseId=@c.Id">
                            Students
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <hr class="my-4" />
}

<h2>All courses</h2>

@if (Model.AllCourses.Count == 0)
{
    <p>No courses yet.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var c in Model.AllCourses)
        {
            <tr>
                <td>@c.Id</td>
                <td>@c.Title</td>
                <td style="display:flex; gap:8px;">
                    <a class="btn btn-sm btn-secondary" href="/Courses/Edit?id=@c.Id">Edit</a>

                    <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id">
                        <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                    </form>

                    <a class="btn btn-sm btn-outline-primary"
                       href="/Enrollments/CourseStudents?courseId=@c.Id">
                        Students
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
