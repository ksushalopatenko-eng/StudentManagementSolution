@page
@model StudentManagementWeb.Pages.Students.EditModel

<h1>Edit student</h1>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <p class="text-danger">@Model.Error</p>
}

<form method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Name</label>
        <input class="form-control" asp-for="Name" />
        <span class="text-danger" asp-validation-for="Name"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Age</label>
        <input class="form-control" asp-for="Age" />
        <span class="text-danger" asp-validation-for="Age"></span>
    </div>

    <button class="btn btn-primary" type="submit">Save</button>
    <a class="btn btn-secondary" href="/Students">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}